# Application Settings
SMARTCOURSE_APP_NAME=SmartCourse
SMARTCOURSE_APP_ENV=development
SMARTCOURSE_DEBUG=True
SMARTCOURSE_API_V1_PREFIX=/api/v1

# Database Settings
SMARTCOURSE_DATABASE_URL=postgresql+asyncpg://smartcourse:smartcourse_password@localhost:5432/smartcourse
SMARTCOURSE_DATABASE_POOL_SIZE=20
SMARTCOURSE_DATABASE_MAX_OVERFLOW=10

# Redis Settings
SMARTCOURSE_REDIS_URL=redis://localhost:6379/0
SMARTCOURSE_REDIS_CACHE_TTL=3600

# RabbitMQ Settings
SMARTCOURSE_RABBITMQ_URL=amqp://smartcourse:smartcourse_password@localhost:5672/
SMARTCOURSE_RABBITMQ_TASK_QUEUE=smartcourse_tasks

# Kafka Settings
SMARTCOURSE_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SMARTCOURSE_KAFKA_CONSUMER_GROUP=smartcourse_group
SMARTCOURSE_KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# Temporal Settings
SMARTCOURSE_TEMPORAL_HOST=localhost
SMARTCOURSE_TEMPORAL_PORT=7233
SMARTCOURSE_TEMPORAL_NAMESPACE=default
SMARTCOURSE_TEMPORAL_TASK_QUEUE=smartcourse_workflows

# Security Settings
SMARTCOURSE_SECRET_KEY=your-secret-key-here-change-in-production
SMARTCOURSE_ALGORITHM=HS256
SMARTCOURSE_ACCESS_TOKEN_EXPIRE_MINUTES=30
SMARTCOURSE_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI/LLM Settings
SMARTCOURSE_OPENAI_API_KEY=your-openai-api-key
SMARTCOURSE_ANTHROPIC_API_KEY=your-anthropic-api-key
SMARTCOURSE_GROQ_API_KEY=your-groq-api-key
SMARTCOURSE_DEFAULT_LLM_PROVIDER=openai

# Vector Database Settings
SMARTCOURSE_QDRANT_URL=http://localhost:6333
SMARTCOURSE_QDRANT_API_KEY=
SMARTCOURSE_QDRANT_COLLECTION_NAME=course_content

# Observability Settings
SMARTCOURSE_JAEGER_AGENT_HOST=localhost
SMARTCOURSE_JAEGER_AGENT_PORT=6831
SMARTCOURSE_JAEGER_SAMPLING_RATE=0.1

# Monitoring Settings
SMARTCOURSE_PROMETHEUS_PORT=9090
SMARTCOURSE_GRAFANA_PORT=3000
SMARTCOURSE_GRAFANA_ADMIN_PASSWORD=admin

# CORS Settings
SMARTCOURSE_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# File Upload Settings
SMARTCOURSE_MAX_UPLOAD_SIZE=10485760
SMARTCOURSE_UPLOAD_DIR=./uploads

# Rate Limiting
SMARTCOURSE_RATE_LIMIT_PER_MINUTE=100
SMARTCOURSE_BURST_LIMIT=200

# Background Worker Settings
SMARTCOURSE_CELERY_BROKER_URL=redis://localhost:6379/1
SMARTCOURSE_CELERY_RESULT_BACKEND=redis://localhost:6379/2
SMARTCOURSE_CELERY_TASK_SOFT_TIME_LIMIT=300
SMARTCOURSE_CELERY_TASK_TIME_LIMIT=600

# ---------------------------------------------------------------------------
# User Service (microservices migration - owns its own database)
# ---------------------------------------------------------------------------
USER_SERVICE_APP_NAME=SmartCourse User Service
USER_SERVICE_DEBUG=True
USER_SERVICE_PORT=8001
USER_SERVICE_DATABASE_URL=postgresql+asyncpg://user_service:user_service_password@localhost:5433/users_db
